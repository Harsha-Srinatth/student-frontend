# Copy to .env — Vite only exposes variables prefixed with VITE_

# Local dev: port must match student-backend PORT (see backend .env)
VITE_API_URL=3000

# Vercel (Production / Preview): set in Project → Settings → Environment Variables
# Use your Render web service URL, no trailing slash:
# VITE_API_URL=https://your-service-name.onrender.com

VITE_GEMINI_API_KEY=
